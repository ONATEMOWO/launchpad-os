{
  "manifest_version": 3,
  "name": "LaunchPad OS Clipper",
  "version": "0.1.0",
  "description": "Send the current page title, URL, and selected text to LaunchPad OS Quick Capture.",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Capture to LaunchPad OS"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
